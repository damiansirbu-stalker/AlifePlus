digraph event_pipeline_radiant {
    // Layout
    rankdir=TB
    splines=ortho
    nodesep=0.6
    ranksep=0.5

    // Defaults
    node [shape=box, style="rounded,filled", fillcolor=white,
          fontsize=14, fontname="Arial", margin="0.12,0.08"]
    edge [fontsize=12, fontname="Arial"]
    graph [fontsize=16, fontname="Arial"]

    // Title
    label="Event Pipeline: Radiant Variant"
    labelloc=t

    // Entry
    entry [label="squad_on_update\n(every squad, every tick)", style="rounded,dashed"]

    // Gates
    g1 [label="PACER\ntimestamp comparison (default 5s)"]
    g2 [label="SCRIPTED\nhash lookup in _ap_scripted_squads"]
    g3 [label="RATIO\nBresenham admission (~4:1 on/off-map)"]
    g4 [label="PROTECTION\ncomposite guard + ownership registry"]
    g5 [label="EVAL\nsliding window + predicate evaluation"]

    // Reject labels (one per gate, no convergence)
    r1 [label="reject", shape=plaintext, fontsize=11, fontcolor=gray40]
    r2 [label="reject", shape=plaintext, fontsize=11, fontcolor=gray40]
    r3 [label="reject", shape=plaintext, fontsize=11, fontcolor=gray40]
    r4 [label="reject", shape=plaintext, fontsize=11, fontcolor=gray40]
    r5 [label="reject", shape=plaintext, fontsize=11, fontcolor=gray40]

    // Exit
    publish [label="cause published to xbus", style="rounded,filled", fillcolor=gray95]

    // Main chain
    entry -> g1
    g1 -> g2
    g2 -> g3
    g3 -> g4
    g4 -> g5
    g5 -> publish

    // Reject paths -- each goes straight right, no crossing
    {rank=same; g1; r1}
    {rank=same; g2; r2}
    {rank=same; g3; r3}
    {rank=same; g4; r4}
    {rank=same; g5; r5}

    g1 -> r1 [style=dashed, color=gray50]
    g2 -> r2 [style=dashed, color=gray50]
    g3 -> r3 [style=dashed, color=gray50]
    g4 -> r4 [style=dashed, color=gray50]
    g5 -> r5 [style=dashed, color=gray50]

    // Pacer retry on protection reject
    g4 -> g1 [xlabel="retry 0.5s", style=dotted, constraint=false]
}
