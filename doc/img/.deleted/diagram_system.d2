direction: down
style.font-size: 16

xray: X-Ray Engine {
  reactive: "X-Ray Events (reactive)\ndeath | medkit | item pickup"
  radiant: "X-Ray Events (radiant)\nsquad_on_update"
}

producer: Producer {
  reactive_gates: "Reactive Gates\nPACER -> RATIO -> EVAL"
  radiant_gates: "Radiant Gates\nPACER -> SCRIPTED -> RATIO\n-> PROTECTION -> EVAL"
  predicate: "Cause Predicate\nevaluate world state"
}

bus: "xbus\ncause event" {
  shape: hexagon
}

consumer: Consumer {
  rate: "Rate Limiting\nglobal + per-type"
  handlers: "Consequence Handlers\npriority-ordered dispatch"
  chain: "Chain Control\nOK_STOP breaks | _NEXT continues"
}

effects: World Effects {
  squad: "Squad Lifecycle\nscript -> arrive -> wait -> release"
  pda: "PDA Messages"
  tracker: "Tracker Updates"
  mutations: "Smart Mutations"
}

xray.reactive -> producer.reactive_gates
xray.radiant -> producer.radiant_gates
producer.reactive_gates -> producer.predicate
producer.radiant_gates -> producer.predicate
producer.predicate -> bus: "publish"
bus -> consumer.rate
consumer.rate -> consumer.handlers
consumer.handlers -> consumer.chain
consumer.chain -> effects.squad
consumer.chain -> effects.pda
consumer.chain -> effects.tracker
consumer.chain -> effects.mutations
