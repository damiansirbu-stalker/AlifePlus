direction: down
style.font-size: 16

core: "Core (ap_core_*)" {
  producer: Producer
  consumer: Consumer
  squad: "Squad\nownership | scripting | arrival | protection"
  limiter: "Limiter\nbudgets | cooldowns"
  debug: "Debug\ntracing | logging"
  utils: "Utils\npub/sub | PDA | find"
}

ext: "Ext (ap_ext_*)" {
  causes: "Causes\npredicates"
  consequences: "Consequences\nhandlers"
  domain: "Domain State\ntracker | smart mutator | object mutator"
}

xlibs: "xlibs\nxbus | xsquad | xsmart | xobject | xlog | xtrace"

engine: "X-Ray Engine\ncallbacks | luabind | A-Life simulation"

ext.causes -> core.producer: "register()" {style.stroke-dash: 3}
ext.consequences -> core.consumer: "register()" {style.stroke-dash: 3}
core -> xlibs
xlibs -> engine
