direction: down
style.font-size: 16

ap: AlifePlus {
  core: "Core" {
    producer: Producer
    consumer: Consumer
    squad: "Squad + Ownership"
    bus: "xbus" {
      shape: hexagon
    }
    producer -> bus: publish
    bus -> consumer: subscribe
  }
  ext: "Ext" {
    causes: Causes
    consequences: Consequences
  }
  ext.causes -> core.producer: "register()"
  ext.consequences -> core.consumer: "register()"
}

your_mod: Your Mod {
  l1: "Level 1: Listen\nxbus.subscribe(cause_event, handler)"
  l2: "Level 2: Register\nproducer.register(predicate)\nconsumer.register(handler)"
  l3: "Level 3: Coordinate\nregister_owner(filter)\nis_protected() | script_squad()"
}

your_mod.l1 -> ap.core.bus: "subscribe" {style.stroke-dash: 3}
your_mod.l2 -> ap.core.producer: "register cause" {style.stroke-dash: 3}
your_mod.l2 -> ap.core.consumer: "register consequence" {style.stroke-dash: 3}
your_mod.l3 -> ap.core.squad: "ownership + lifecycle" {style.stroke-dash: 3}
