digraph dispatch_pipeline {
    // Layout
    rankdir=TB
    splines=ortho
    nodesep=0.6
    ranksep=0.6

    // Defaults
    node [shape=box, style="rounded,filled", fillcolor=white,
          fontsize=14, fontname="Arial", margin="0.12,0.08"]
    edge [fontsize=12, fontname="Arial"]
    graph [fontsize=16, fontname="Arial"]

    // Title
    label="Dispatch Pipeline"
    labelloc=t

    // Entry
    entry [label="xbus delivers cause event", style="rounded,dashed"]

    // Global rate limit
    global [label="Global Rate Limit\nsliding window TTL counter\nbudget exhausted -> break entire loop"]

    // Loop boundary
    loop_start [label="for each consequence (priority order)", shape=parallelogram,
                fontsize=12, style=filled, fillcolor=gray95]

    // Per-key rate limit
    per_key [label="Per-Key Rate Limit\ntoken bucket: peek (check) then acquire (on success)"]

    // Condition
    condition [label="Condition Pre-filter\noptional registration filter"]

    // Handler
    handler [label="Handler Execution\nconsequence function runs"]

    // Result
    result [label="Result Code"]

    // Result branches
    ok_stop [label="OK_STOP\nexclusive success", fontsize=12]
    ok_next [label="OK_NEXT\nnon-exclusive success", fontsize=12]
    skip [label="RULES_NEXT | CHANCE_NEXT\nDISABLED_NEXT | THROTTLED_NEXT", fontsize=11]
    error [label="ERROR_STOP\nabort chain", fontsize=12]

    // Counter
    counter [label="increment global +\nper-key counters", fontsize=12, style="rounded,dashed"]

    // Effects
    effects [label="World Effects\nSquad Lifecycle | PDA | Tracker | Mutations", style="rounded,dashed"]

    // Skip labels
    skip_r [label="skip", shape=plaintext, fontsize=11, fontcolor=gray40]
    skip_c [label="skip", shape=plaintext, fontsize=11, fontcolor=gray40]

    // Main chain
    entry -> global
    global -> loop_start
    loop_start -> per_key
    per_key -> condition
    condition -> handler
    handler -> result

    // Result branching
    result -> ok_stop
    result -> ok_next
    result -> skip
    result -> error

    // Success path
    ok_stop -> counter
    ok_next -> counter
    counter -> effects

    // ok_next loops back
    ok_next -> loop_start [xlabel="next consequence", style=dotted, constraint=false]

    // Skip loops back
    skip -> loop_start [xlabel="next consequence", style=dotted, constraint=false]

    // Skip paths from rate limit and condition
    {rank=same; per_key; skip_r}
    {rank=same; condition; skip_c}
    per_key -> skip_r [style=dashed, color=gray50]
    condition -> skip_c [style=dashed, color=gray50]

    // Stop paths
    ok_stop -> effects [style=invis]
    error -> effects [style=invis]
}
