; AlifePlus trade policy. Two stalker tiers split by RANK_VETERAN (12000, per ap_core_const).
; Entry order in each block = BUY priority (top entries fill first; cash exhausted = stop).
; Min/max counted in rounds for ammo categories (per xinventory D5), items otherwise.
; Sell-only categories use min=0, max=0 -- min=0 means count<0 never triggers buy.
; Pre-filter ("untouchable" + "equipped") bypasses policy entirely; never reached here.
; A row keyed by an item section (e.g. grenade_smoke) is a per-section override: it counts
; and caps that section on its own, separate from its category. min/max work the same as a
; category row: grenade_smoke = 0, 0 keeps NPCs from buying smoke and sells off any they
; carry (engine crash on NPC throw), while a positive min like grenade_f1 = 2, 2 makes NPCs
; buy that exact section up to 2. Ammo sections count in rounds; item sections in items.
; The grenade category still trades other grenades alongside any section override.

[ap_trade_policy_rookie]
ammo_slot_3_t1    = 15, 15
ammo_slot_2_t1    = 16, 16
ammo_slot_3_t2    = 0, 0
ammo_slot_2_t2    = 0, 0
ammo_not_equipped = 0, 0
grenade           = 0, 0
grenade_smoke     = 0, 0    ; excluded: engine crash when NPCs throw smoke grenades
grenade_ammo      = 0, 0
medkit            = 1, 3
bandage           = 1, 3
stim              = 0, 1
antirad           = 0, 0
pill              = 0, 0
food              = 0, 0
drink             = 0, 0
weapon            = 0, 0
outfit            = 0, 0
helmet            = 0, 0
artefact          = 0, 0
device            = 0, 0
money             = 0, 0
crafting          = 0, 0
other             = 0, 0

[ap_trade_policy_veteran]
ammo_slot_3_t1    = 15, 15
ammo_slot_2_t1    = 16, 16
ammo_slot_3_t2    = 15, 15
ammo_slot_2_t2    = 16, 16
