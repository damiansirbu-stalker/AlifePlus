<string_table>
  <!-- =========================================================================
 CHATTER TEMPLATES

 Immediate, local lines pushed by a producer (the market today), spoken by a nearby
 stalker on the PDA feed. Id pattern: st_ap_chatter_[type]_NNN, NNN runs 001..020.
 Slots: #trader# (trader name), #item# (item name), #location# (level name).
 ========================================================================== -->

  <string id="st_ap_chatter_market_001">
    <text>Heard #trader# came into some #item#.</text>
  </string>
  <string id="st_ap_chatter_market_002">
    <text>Word is #trader# took in #item#, and it will not sit long.</text>
  </string>
  <string id="st_ap_chatter_market_003">
    <text>Somebody said #trader# is holding #item# right now.</text>
  </string>
  <string id="st_ap_chatter_market_004">
    <text>They are saying #trader# in #location# got #item# in.</text>
  </string>
  <string id="st_ap_chatter_market_005">
    <text>#trader# took in #item#. Worth a look before it is gone.</text>
  </string>
</string_table>
