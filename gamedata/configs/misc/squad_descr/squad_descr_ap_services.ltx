;; AlifePlus service-filler squads. Auto-included via the squad_descr_*.ltx wildcard.
;; Each is a single-NPC group wrapping the vanilla sim_default_<faction>_<role> profile (which
;; carries the service dialog: dm_init_trader / dm_init_mechanic / medic + supplies stub). A
;; conquered outpost spawns one of these through the smart's respawn_params
;; (xsmart_spawn.set_shared_spawn_section), then xcreature.make_trader applies a vanilla trade
;; config so the shop / repair / heal has stock. The NPC keeps its FACTION community (never
;; "trader"), so it slots into that faction's market. See n490 CONQUER_OUTPOST.

[ap_service_army_trader]:online_offline_group
faction = army
npc_random = sim_default_army_trader
npc_in_squad = 1,1
always_arrived = true

