    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local spawned, skipped = _spawn_kit_items(KIT_CONSUMABLES_ITEMS, "kit_consumables")
    _tip(string_format("Kit consumables: %d items, %d skipped", spawned, skipped))
    ap_core_debug.debug("[TEST] kit_consumables OK spawned=%d skipped=%d", spawned, skipped)
end

local NPC_GIFT_ITEMS = {
    -- meds (heal_shelter consume + trade sell)
    { sec = "bandage",            count = 10 },
    { sec = "medkit",             count = 5 },
    { sec = "medkit_army",        count = 5 },
    -- mutant parts (harvest cause + trade sell)
    { sec = "meat_flesh_b",       count = 3 },
    { sec = "meat_boar_b",        count = 3 },
    { sec = "meat_dog_b",         count = 4 },
    -- weapon + ammo (equipped-rifle ammo buy phase of trade + combat use)
    { sec = "wpn_mossberg590",    count = 1 },
    { sec = "ammo_12x70_buck",    count = 90 },
}

local GIFT_NPCS_QUEUE = "ap_test_gift_npcs"
local GIFT_NPCS_STEP  = 3
local _gift_npcs_state = nil

local function _gift_one_npc(npc_id)
    local items = _gift_npcs_state.items
    for i = 1, #items do
        local item = items[i]
        for _ = 1, item.count do
            xinventory.create_item(item.sec, npc_id)
        end
        _gift_npcs_state.items_spawned = _gift_npcs_state.items_spawned + item.count
    end
    _gift_npcs_state.npcs_done = _gift_npcs_state.npcs_done + 1
end

--- Fill every online stalker NPC on the actor's level with a playtest inventory kit.
--- Primes item flows: bandages + medkits exercise the supply_trader consumable buy/sell
--- bands; mutant parts and ammo exercise the sell phase + harvest cause; the mossberg +
--- ammo make the equipped-slot detection non-trivial for the buy phase.
--- Frame-spread via xslice (step=3 NPCs/frame) so a fully-populated level does not stall
--- a frame. Re-press to cancel an in-flight queue.
--- @export console
function gift_npcs()
    ap_core_debug.debug("[TEST] gift_npcs pressed")
    if xslice.is_active(GIFT_NPCS_QUEUE) then
        xslice.cancel(GIFT_NPCS_QUEUE, true)
        _gift_npcs_state = nil
        _tip("Gift NPCs: cancelled")
        ap_core_debug.debug("[TEST] gift_npcs cancelled")
        return
    end

    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local actor_se = alife():actor()
    if not actor_se then return _tip("No actor entity") end
    local actor_level = xlevel.get_level_id(actor_se)
    local actor_id = actor:id()

    local valid_items, missing = {}, {}
    for i = 1, #NPC_GIFT_ITEMS do
        local item = NPC_GIFT_ITEMS[i]
        if ini_sys:section_exist(item.sec) then
            valid_items[#valid_items + 1] = item
        else
            missing[#missing + 1] = item.sec
        end
    end
    if #missing > 0 then
        ap_core_debug.debug("[TEST] gift_npcs missing sections: %s", table.concat(missing, ","))
    end
    if #valid_items == 0 then return _tip("Gift NPCs: no valid item sections") end

    local candidates = {}
    for npc_id in pairs(db.storage) do
        if npc_id == actor_id then goto skip end
        local obj = xobject.go(npc_id)
        if not obj then goto skip end
        if not obj:alive() then goto skip end
        if not IsStalker(obj) then goto skip end
        local se = xobject.se(npc_id)
        if not se then goto skip end
        if xlevel.get_level_id(se) ~= actor_level then goto skip end
        if xdata.unscriptable_npcs[se:section_name()] then goto skip end
        candidates[#candidates + 1] = npc_id
        ::skip::
    end
    if #candidates == 0 then return _tip("No online stalker NPCs on this level") end

    _gift_npcs_state = { npcs_done = 0, items_spawned = 0, total = #candidates, items = valid_items }
    ap_core_debug.debug("[TEST] gift_npcs start npcs=%d valid_secs=%d missing=%d step=%d",
        #candidates, #valid_items, #missing, GIFT_NPCS_STEP)

    xslice.start(GIFT_NPCS_QUEUE, candidates, {
        step = GIFT_NPCS_STEP,
        func = function(npc_id) _gift_one_npc(npc_id) return true end,
        on_done = function()
            local state = _gift_npcs_state
            _tip(string_format("Gift NPCs: %d NPCs / %d items", state.npcs_done, state.items_spawned))
            ap_core_debug.debug("[TEST] gift_npcs OK npcs=%d items=%d", state.npcs_done, state.items_spawned)
            _gift_npcs_state = nil
        end,
    })
    _tip(string_format("Gift NPCs: queued %d NPCs (%d/frame)", #candidates, GIFT_NPCS_STEP))
end

local _test_marker_ids = {}
local _test_marker_spots = {
    "red_location", "green_location", "blue_location",
    "circle_small_red", "circle_small_green", "circle_small_yellow", "circle_empty",
    "crlc_mdl", "crlc_small", "crlc_squad_red", "crlc_squad_green",
    "circle_target", "warfare_selected_target",
    "warfare_friendly_spot_moving", "warfare_enemy_spot_moving", "warfare_neutral_spot_moving",
    "alife_presentation_squad_friend", "alife_presentation_squad_enemy", "alife_presentation_squad_neutral",
    "alife_presentation_squad_monster",
    "alife_presentation_faction_stalker", "alife_presentation_faction_dolg",
    "alife_presentation_faction_freedom", "alife_presentation_faction_bandit",
    "alife_presentation_faction_killer", "alife_presentation_faction_monster",
    "alife_combat", "alife_combat_fight",
    "circle_stalker", "circle_dolg", "circle_freedom", "circle_bandit",
    "circle_killer", "circle_monolith", "circle_army",
}

--- @safety pcall required: map_add_object_spot crashes on invalid spot types (engine API)
local function _try_add_spot(id, spot)
    return pcall(level.map_add_object_spot, id, spot, spot)
end

--- @safety pcall required: map_remove_object_spot crashes on missing spots (engine API)
local function _try_remove_spot(id, spot)
    return pcall(level.map_remove_object_spot, id, spot)
end

--- Place all map spot types on squads across the level so you can see what each looks like
--- @export console
function show_markers()
    ap_core_debug.debug("[TEST] show_markers pressed")
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local actor_se = alife():actor()
    if not actor_se then return _tip("No actor entity") end
    local actor_level = xlevel.get_level_id(actor_se)

    local ids = {}
    for squad in xsquad.iter_squads() do
        if xlevel.get_level_id(squad) == actor_level then
            ids[#ids + 1] = squad.id
        end
    end
    if #ids == 0 then return _tip("No squads on level") end

    _test_marker_ids = {}
    local placed = 0
    for i = 1, math_min(#_test_marker_spots, #ids) do
        if _try_add_spot(ids[i], _test_marker_spots[i]) then
            placed = placed + 1
            _test_marker_ids[#_test_marker_ids + 1] = ids[i]
        end
    end

    _tip(string_format("Placed %d/%d marker types across %d squads", placed, #_test_marker_spots, #ids))
    ap_core_debug.debug("[TEST] show_markers OK placed=%d total=%d squads=%d", placed, #_test_marker_spots, #ids)
end

--- Clear all test markers placed by show_markers
--- @export console
function clear_markers()
    ap_core_debug.debug("[TEST] clear_markers pressed")
    for _, sq_id in ipairs(_test_marker_ids) do
        for _, spot in ipairs(_test_marker_spots) do
            _try_remove_spot(sq_id, spot)
        end
    end
    _test_marker_ids = {}
    _tip("Cleared test markers")
end

--- Spawn a mutant nearby and promote it to alpha for loot testing
--- @export console
function spawn_alpha()
    ap_core_debug.debug("[TEST] spawn_alpha pressed")
    local actor = xobject.go(0)
    if not actor then return _tip("Not in game") end
    local pos = actor:position()
    local spawn_pos = vector():set(pos.x + 5, pos.y, pos.z + 5)
    local lvid = actor:level_vertex_id()
    local gvid = actor:game_vertex_id()
    local section = "pseudodog_grey_strong"
    if not ini_sys:section_exist(section) then section = "pseudodog_grey_weak" end
    local se = alife():create(section, spawn_pos, lvid, gvid)
    if not se then
        ap_core_debug.debug("[TEST] spawn_alpha FAIL alife create")
        return _tip("Failed to spawn mutant")
    end
    local npc_id = se.id
    local test_level = 8
    local test_kills = test_level * ap_core_mcm.cfg.cause_alpha_kills_per_level
    ap_ext_tracker.update_alpha(npc_id, { kills = test_kills })
    ap_core_debug.debug("[TEST] spawn_alpha OK id=%d section=%s level=%d kills=%d", npc_id, section, test_level, test_kills)
    _tip(string_format("Spawned alpha L%d %s (id=%d)", test_level, section, npc_id))
end

--- NEEDS DEMO: integration test - fires real needs pipeline for nearby squads
--- Forces specific observable leisure needs (eating, guitar, sleeping).
--- Full stack: alife_ratio -> event_limiter -> cause_rate -> predicate -> xbus ->
--- consumer -> consequence -> script_squad -> arrival -> PDA.

local DEMO_MAX_SQUADS = 5
local DEMO_MIN_INTERVAL_MS = 2000

local DEMO_NEEDS = {
    { need = "hunger", field = "last_hunger_at" },
    { need = "job",    field = "last_job_at" },
    { need = "social", field = "last_social_at" },
    { need = "rest",   field = "last_rest_at" },
}

local _demo_queue = {}
local _demo_next_fire = 0
local _demo_active = false
local _demo_need_idx = 0
local _demo_saved_causes = nil

--- Check if online NPC is a valid demo candidate (alive, not actor, passes type predicate)
local function _is_demo_candidate(npc_id, is_type)
    local obj = xobject.go(npc_id)
    if not obj then return false end
    if not obj:alive() then return false end
    if obj:id() == 0 then return false end
    local type_ok = is_type(obj)
    if not type_ok then return false end
    return true, obj
end

--- Find nearby online squads sorted by distance. Alignment defaults to humans, type to IsStalker.
local function _find_demo_squads(max_count, alignment, is_type)
    alignment = alignment or ap_ext_const.alignment_human
    is_type = is_type or IsStalker
    local actor = db.actor
    if not actor then return {} end
    local actor_pos = actor:position()
    local seen = {}
    local candidates = {}
    for npc_id in pairs(db.storage) do
        local ok, obj = _is_demo_candidate(npc_id, is_type)
        if not ok then goto skip end
        local squad = xsquad.get_squad_by_member(npc_id)
        if not squad then goto skip end
        if seen[squad.id] then goto skip end
        if not alignment[squad.player_id] then goto skip end
        seen[squad.id] = true
        candidates[#candidates + 1] = { squad = squad, dist = actor_pos:distance_to_sqr(obj:position()) }
        ::skip::
    end
    table_sort(candidates, function(a, b) return a.dist < b.dist end)
    local squads = {}
    for i = 1, math_min(max_count, #candidates) do
        squads[i] = candidates[i].squad
    end
    return squads
end

local DEMO_COMPETING_KEYS = {
    "cause_stash_loot_enabled", "cause_stash_ambush_enabled", "cause_stash_fill_enabled",
    "cause_area_conquer_enabled", "cause_area_swarm_enabled", "cause_area_infest_enabled",
}

local function _demo_disable_competing_causes()
    local mcm = ap_core_mcm.cfg
    _demo_saved_causes = {}
    for i = 1, #DEMO_COMPETING_KEYS do
        local k = DEMO_COMPETING_KEYS[i]
        _demo_saved_causes[k] = mcm[k]
        mcm[k] = false
    end
    ap_core_debug.debug("[TEST] needs_demo disabled competing causes")
end

local function _demo_restore_causes()
    if not _demo_saved_causes then return end
    local mcm = ap_core_mcm.cfg
    for i = 1, #DEMO_COMPETING_KEYS do
        local k = DEMO_COMPETING_KEYS[i]
        mcm[k] = _demo_saved_causes[k]
    end
    ap_core_debug.debug("[TEST] needs_demo restored causes")
    _demo_saved_causes = nil
end

local function _demo_fire_next()
    if not _demo_active then return end
    if #_demo_queue == 0 then
        _demo_active = false
        _demo_restore_causes()
        UnregisterScriptCallback(ap_core_const.CALLBACK.ACTOR_ON_UPDATE, _demo_fire_next)
        _tip("Needs demo: complete")
        ap_core_debug.debug("[TEST] needs_demo complete")
        return
    end
    local now = time_global()
    if now < _demo_next_fire then return end

    local squad = table_remove(_demo_queue, 1)
    _demo_need_idx = _demo_need_idx % #DEMO_NEEDS + 1
    local demo_need = DEMO_NEEDS[_demo_need_idx]

    ap_ext_tracker.force_stalker_need(squad.id, demo_need.field)
    -- Fire the radiant heartbeat directly (changed=nil, a keepalive-shaped turn); the demo
    -- bypasses the sweep, so the forced need is evaluated on this squad immediately.
    SendScriptCallback(ap_core_const.CALLBACK.AP_SQUAD_ON_CHANGE, squad)

    local interval_ms = DEMO_MIN_INTERVAL_MS
    _demo_next_fire = now + interval_ms

    ap_core_debug.debug("[TEST] needs_demo fired squad=%d faction=%s need=%s remaining=%d interval=%dms",
        squad.id, squad.player_id, demo_need.need, #_demo_queue, math_floor(interval_ms))
    _tip(string_format("Needs demo: squad %d -> %s (%d remaining)", squad.id, demo_need.need, #_demo_queue))
end

--- NEWS DEMO: periodically seeds random activity records to exercise every consequence.
--- Tests the news composer in isolation: broker.record -> composer -> xpda. Bypasses the
--- pipeline so every seed lands. Mutant-subject consequences seed from nearby mutant squads
--- so #subject_species# populates.
--- Toggle on/off. Set MCM news_interval_min/max_sec low (e.g. 1-3) for rapid feedback.

local NEWS_DEMO_SEED_INTERVAL_MS = 2000

-- Subject alignment overrides. Default is "human"; list mutant-subject consequences here.
local NEWS_DEMO_SUBJECT_MUTANT = {
    [CONSEQUENCE.ALPHA_PROMOTE]      = true,
    [CONSEQUENCE.ALPHAKILL_TARGETED] = true,
    [CONSEQUENCE.MASSACRE_SCAVENGE]  = true,
    [CONSEQUENCE.WOUNDED_HUNT]       = true,
    [CONSEQUENCE.HARVEST_HAUNT]      = true,
    [CONSEQUENCE.AREA_SWARM]         = true,
    [CONSEQUENCE.AREA_INFEST]        = true,
    [CONSEQUENCE.FEED]               = true,
    [CONSEQUENCE.SLUMBER_FIELD]      = true,
    [CONSEQUENCE.SLUMBER_LAIR]       = true,
    [CONSEQUENCE.SLUMBER_SURGE]      = true,
    [CONSEQUENCE.ROAM]               = true,
    [CONSEQUENCE.PACK]               = true,
    [CONSEQUENCE.SCATTER]            = true,
}

-- Other-side alignment. Absent = single-party (no other_squad).
local NEWS_DEMO_OTHER_KIND = {
    [CONSEQUENCE.MASSACRE_INVESTIGATE] = "human",
    [CONSEQUENCE.MASSACRE_SCAVENGE]    = "human",
    [CONSEQUENCE.MASSACRE_LOOT]        = "human",
    [CONSEQUENCE.SQUADKILL_REVENGE]    = "human",
    [CONSEQUENCE.BASEKILL_SUPPORT]     = "human",
    [CONSEQUENCE.BASEKILL_FLEE]        = "human",
    [CONSEQUENCE.ALPHAKILL_TARGETED]   = "human",
    [CONSEQUENCE.WOUNDED_HUNT]         = "human",
    [CONSEQUENCE.WOUNDED_HELP]         = "human",
    [CONSEQUENCE.HARVEST_ROB]          = "human",
    [CONSEQUENCE.HARVEST_HAUNT]        = "human",
}

-- Walk CONSEQUENCE enum, resolve cause via consumer registry, attach kind/other.
-- Enum entries with no registration land in `unregistered` and trigger a warn.
local _news_demo_events_cache = nil
local function _news_demo_events()
    if _news_demo_events_cache then return _news_demo_events_cache end
    local events, unregistered = {}, {}
    for _, cons in pairs(CONSEQUENCE) do
        local cause = ap_core_consumer.cause_of(cons)
        if cause then
            events[#events + 1] = {
                cause = cause,
                cons  = cons,
                kind  = NEWS_DEMO_SUBJECT_MUTANT[cons] and "mutant" or "human",
                other = NEWS_DEMO_OTHER_KIND[cons],
            }
        else
            unregistered[#unregistered + 1] = cons
        end
    end
    if #unregistered > 0 then
        ap_core_debug.warn("[TEST] news_demo: %d enum entries unregistered with consumer: %s",
            #unregistered, table.concat(unregistered, ","))
    end
    _news_demo_events_cache = events
    return events
end

local _news_demo_active = false
local _news_demo_next_seed = 0

-- Resolve alignment set + type predicate for subject-squad search
local function _news_demo_alignment(kind)
    if kind == "mutant" then return ap_ext_const.alignment_mutant, IsMonster end
    return ap_ext_const.alignment_human, IsStalker
end

local function _news_demo_pick_squad(kind)
    if not kind then return nil end
    local alignment, is_type = _news_demo_alignment(kind)
    local squads = _find_demo_squads(20, alignment, is_type)
    if #squads == 0 then return nil end
    return xmath.sample(squads)
end

-- Seed one activity record. Returns true on write, false if no squad available.
-- For two-party events, ensures other_squad has a different faction than subject so
-- templates don't render "Bandit vs Bandit"-style artifacts.
local function _news_demo_seed_record(squad, cause, consequence, other_kind)
    if not squad then return false end
    local smart = xsquad.get_squad_smart(squad)
    local level_id = xlevel.get_level_id(squad)
    local other_squad = _news_demo_pick_squad(other_kind)
    if other_squad and other_squad.player_id == squad.player_id then
        other_squad = _news_demo_pick_squad(other_kind)
        if other_squad and other_squad.player_id == squad.player_id then other_squad = nil end
    end
    ap_core_record.add_record(squad, cause, consequence, {
        action_key  = (consequence:gsub("^consequence:", "action:")),
        other_squad = other_squad,
        smart       = smart,
        level_id    = level_id,
    })
    return true
end

local function _news_demo_seed_one()
    local events = _news_demo_events()
    if #events == 0 then return nil end
    local event = xmath.sample(events)
    local squad = _news_demo_pick_squad(event.kind)
    if not squad then return nil end
    _news_demo_seed_record(squad, event.cause, event.cons, event.other)
    return event
end

local function _news_demo_tick()
    if not _news_demo_active then return end
    local now = time_global()
    if now < _news_demo_next_seed then return end
    _news_demo_next_seed = now + NEWS_DEMO_SEED_INTERVAL_MS
    local event = _news_demo_seed_one()
    if event then
        ap_core_debug.debug("[TEST] news_demo seeded cons=%s", event.cons)
    end
end

--- Toggle perpetual random-event seeder. Real composer dispatches based on MCM interval.
--- @export console
function news_demo()
    ap_core_debug.debug("[TEST] news_demo pressed")
    if _news_demo_active then
        _news_demo_active = false
        UnregisterScriptCallback(ap_core_const.CALLBACK.ACTOR_ON_UPDATE, _news_demo_tick)
        _tip("News demo stopped")
        ap_core_debug.debug("[TEST] news_demo stopped")
        return
    end
    _news_demo_active = true
    _news_demo_next_seed = 0
    RegisterScriptCallback(ap_core_const.CALLBACK.ACTOR_ON_UPDATE, _news_demo_tick)
    _tip(string_format("News demo: seeding random event every %ds", NEWS_DEMO_SEED_INTERVAL_MS / 1000))
    ap_core_debug.debug("[TEST] news_demo started interval_ms=%d events=%d",
        NEWS_DEMO_SEED_INTERVAL_MS, #_news_demo_events())
end

--- @export console
function needs_demo()
    if _demo_active then
        _demo_active = false
        _demo_queue = {}
        _demo_restore_causes()
        UnregisterScriptCallback(ap_core_const.CALLBACK.ACTOR_ON_UPDATE, _demo_fire_next)
        _tip("Needs demo stopped")
        ap_core_debug.debug("[TEST] needs_demo stopped")
        return
    end
    local squads = _find_demo_squads(DEMO_MAX_SQUADS)
    if #squads == 0 then return _tip("No stalker squads nearby") end
    _demo_queue = squads
    _demo_active = true
    _demo_next_fire = 0
    _demo_need_idx = 0
    _demo_disable_competing_causes()
    RegisterScriptCallback(ap_core_const.CALLBACK.ACTOR_ON_UPDATE, _demo_fire_next)
    _tip(string_format("Needs demo: %d squads queued (hunger/job/social/rest)", #squads))
    ap_core_debug.debug("[TEST] needs_demo started squads=%d needs=hunger,job,social,sleep", #squads)
end

