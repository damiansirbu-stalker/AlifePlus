--- ap_ext_test: MCM debug tools and demo harnesses

local pairs, ipairs, pcall, table, tostring = pairs, ipairs, pcall, table, tostring
local table_sort, table_remove, math_min = table.sort, table.remove, math.min
local math_floor, math_huge = math.floor, math.huge
local string_format, time_global = string.format, time_global
local character_community, IsStalker, IsMonster = character_community, IsStalker, IsMonster
local UnregisterScriptCallback, RegisterScriptCallback = UnregisterScriptCallback, RegisterScriptCallback
local xobject, xsquad, xmath, xactor, xcreature, xlevel, xslice, xdata, xinventory = xobject, xsquad, xmath, xactor, xcreature, xlevel, xslice, xdata, xinventory
local ap_core_debug, ap_core_broker, ap_core_record, ap_core_consumer, ap_core_mcm = ap_core_debug, ap_core_broker, ap_core_record, ap_core_consumer, ap_core_mcm
local ap_core_const, ap_ext_const, ap_ext_tracker = ap_core_const, ap_ext_const, ap_ext_tracker

local ARTEFACTS = {
    "af_medusa", "af_cristall_flower", "af_fireball",
    "af_electra_sparkler", "af_gravi", "af_gold_fish",
    "af_mincer_meat", "af_eye",
}

local function _tip(msg)
    local actor = db.actor
    if actor then news_manager.send_tip(actor, msg, nil, nil, 5000) end
end

-- Console harness for the n482 chase primitive (homing only; the evaluate_chase leash is
-- verified in-game, not by this harness). Commands:
--   chase(chaser_id, target_id) -- explicit: any squad pursues any squad. The workhorse.
--   chase_near()                -- nearest squad pursues 2nd-nearest (ONLINE homing smoke).
--   chase_far()                 -- farthest (likely OFFLINE) squad pursues the nearest, so the
--                                  get_current_task offline-movement hook is exercised; poll
--                                  chase_status to watch the off-screen chaser close (gvid/dist).
--   chase_status(chaser_id)     -- online?/level/gvid/assigned/current_action + target/dist.
--   chase_stop(chaser_id)       -- release.
-- Test surface: online homing (chase_near), offline homing (chase_far), online<->offline
-- transition (chase_near then walk away), target death (chase a hostile, let it die -> release),
-- save/load (chase then save+reload -> chase_status shows assigned still = target).

-- Pick the nearest (want_far=false) or farthest (want_far=true) squad to apos on level_id.
local function _pick_squad(apos, level_id, exclude_id, want_far)
    local best, best_dist = nil, nil
    for squad in xsquad.iter_squads() do
        if squad.id == exclude_id then goto continue end
        if xlevel.get_level_id(squad) ~= level_id then goto continue end
        local sep_dist = apos:distance_to(squad.position)
        if not best_dist or (want_far and sep_dist > best_dist) or (not want_far and sep_dist < best_dist) then
            best, best_dist = squad, sep_dist
        end
        ::continue::
    end
    return best
end

--- @export console
function chase(chaser_id, target_id)
    local chaser = chaser_id and xobject.se(chaser_id)
    local target = target_id and xobject.se(target_id)
    if not (chaser and target) then return _tip("need valid chaser/target ids") end
    local res = ap_core_broker.script_squad_target(chaser, target_id)
    ap_core_debug.debug("[TEST] chase chaser=%d target=%d code=%s", chaser_id, target_id, tostring(res.code))
    _tip(string_format("chase %d -> %d : %s", chaser_id, target_id, tostring(res.code)))
end

--- @export console
function chase_near()
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local level_id = xlevel.get_level_id(alife():actor())
    local apos = actor:position()
    local chaser = _pick_squad(apos, level_id, nil, false)
    if not chaser then return _tip("No squad on level") end
    local target = _pick_squad(apos, level_id, chaser.id, false)
    if not target then return _tip("Need 2 squads on level") end
    chase(chaser.id, target.id)
end

--- @export console
function chase_far()
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local level_id = xlevel.get_level_id(alife():actor())
    local apos = actor:position()
    local chaser = _pick_squad(apos, level_id, nil, true)
    if not chaser then return _tip("No squad on level") end
    local target = _pick_squad(apos, level_id, chaser.id, false)
    if not target then return _tip("Need 2 squads on level") end
    chase(chaser.id, target.id)
    _tip(string_format("OFFLINE chase: far %d -> near %d (poll chase_status)", chaser.id, target.id))
end

--- @export console
function chase_status(chaser_id)
    local chaser = chaser_id and xobject.se(chaser_id)
    if not chaser then return _tip("No squad " .. tostring(chaser_id)) end
    local entry = ap_core_broker.get_scripted_squads()[chaser_id]
    local target_id = entry and entry.target_squad_id
    local target = target_id and xobject.se(target_id)
    local sep_dist = target and chaser.position:distance_to(target.position) or -1
    ap_core_debug.debug("[TEST] chase_status chaser=%d online=%s lvl=%s gvid=%s assigned=%s act=%s | target=%s online=%s dist=%.1f",
        chaser_id, tostring(chaser.online), tostring(xlevel.get_level_id(chaser)), tostring(chaser.m_game_vertex_id),
        tostring(chaser.assigned_target_id), tostring(chaser.current_action),
        tostring(target_id), target and tostring(target.online) or "nil", sep_dist)
    _tip(string_format("c=%d on=%s assigned=%s act=%s dist=%.1f",
        chaser_id, tostring(chaser.online), tostring(chaser.assigned_target_id), tostring(chaser.current_action), sep_dist))
end

--- @export console
function chase_stop(chaser_id)
    local ok = chaser_id and ap_core_broker.release_squad(chaser_id)
    _tip("chase_stop " .. tostring(chaser_id) .. " -> " .. tostring(ok))
end

-- Automatic homing probe. chase_probe() / chase_probe_far() start a chase, then sample it on a
-- timer (no manual polling) and print a verdict in a news tip + [TEST] probe lines in alifeplus.log:
--   PASS         = lock held + distance closed (homing works).
--   LOCK LOST    = chaser dropped the (still-alive) target mid-chase (arrival machine misbehaves).
--   INCONCLUSIVE = no closing -- target stationary/blocked, re-run elsewhere.
-- chase_probe = nearest vs 2nd-nearest (online, ~30s). chase_probe_far = farthest (offline) chaser
-- vs nearest (exercises the get_current_task offline-movement hook, ~90s).
local _probe = nil

-- One sample: advance tick, log dist/state, track start/last dist and first lock-loss.
local function _probe_sample(probe)
    local chaser = xobject.se(probe.chaser_id)
    local target = xobject.se(probe.target_id)
    probe.ticks = probe.ticks + 1
    local sep_dist = (chaser and target) and chaser.position:distance_to(target.position) or -1
    local assigned = chaser and chaser.assigned_target_id
    ap_core_debug.debug("[TEST] probe t=%d dist=%.1f act=%s assigned=%s on=%s target_alive=%s",
        probe.ticks, sep_dist, tostring(chaser and chaser.current_action),
        tostring(assigned), tostring(chaser and chaser.online), tostring(target ~= nil))
    if sep_dist >= 0 then
        if probe.start_dist < 0 then probe.start_dist = sep_dist end
        probe.last_dist = sep_dist
    end
    if assigned ~= probe.target_id and not probe.lost_at then
        probe.lost_at = probe.ticks
        if target then
            probe.lost_members = target:npc_count()
        else
            probe.lost_members = 0
        end
    end
end

local function _probe_verdict(probe)
    if probe.lost_at and (probe.lost_members or 0) <= 0 then
        return string_format("TARGET DIED at t=%d (correct release)", probe.lost_at)
    end
    if probe.lost_at then
        return string_format("LOCK LOST at t=%d (BUG: target had %d members)", probe.lost_at, probe.lost_members)
    end
    local closed_dist = probe.start_dist - probe.last_dist
    if probe.start_dist >= 0 and closed_dist > 5 then
        return string_format("PASS closed %.0f -> %.0f", probe.start_dist, probe.last_dist)
    end
    return string_format("INCONCLUSIVE dist %.0f -> %.0f (target stationary?)", probe.start_dist, probe.last_dist)
end

local function _probe_tick()
    local probe = _probe
    if not probe then return true end
    -- Abort cleanly if the chase was released externally (e.g. chase_stop).
    if not ap_core_broker.get_scripted_squads()[probe.chaser_id] then
        ap_core_debug.debug("[TEST] probe aborted (chase released) chaser=%d", probe.chaser_id)
        _probe = nil
        return true
    end
    _probe_sample(probe)
    if probe.ticks < probe.max then
        ResetTimeEvent("ap_ext_test", "chase_probe", probe.interval)
        return false
    end
    local verdict = _probe_verdict(probe)
    ap_core_debug.debug("[TEST] probe verdict chaser=%d: %s", probe.chaser_id, verdict)
    _tip("PROBE " .. verdict)
    ap_core_broker.release_squad(probe.chaser_id)
    _probe = nil
    return true
end

local function _probe_start(chaser, target, max_ticks, interval_sec)
    if _probe then return _tip("probe already running; wait or chase_stop") end
    local res = ap_core_broker.script_squad_target(chaser, target.id)
    if res.code ~= ap_core_const.RESULT.SUCCESS then
        return _tip("probe dispatch failed: " .. tostring(res.reason))
    end
    _probe = {
        chaser_id = chaser.id, target_id = target.id,
        ticks = 0, max = max_ticks, interval = interval_sec,
        start_dist = -1, last_dist = -1, lost_at = nil,
    }
    ap_core_debug.debug("[TEST] probe start chaser=%d target=%d max=%d interval=%d",
        chaser.id, target.id, max_ticks, interval_sec)
    _tip(string_format("PROBE start %d -> %d (~%ds)", chaser.id, target.id, max_ticks * interval_sec))
    CreateTimeEvent("ap_ext_test", "chase_probe", interval_sec, _probe_tick)
end

--- @export console
function chase_probe()
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local level_id = xlevel.get_level_id(alife():actor())
    local apos = actor:position()
    local chaser = _pick_squad(apos, level_id, nil, false)
    if not chaser then return _tip("No squad on level") end
    local target = _pick_squad(apos, level_id, chaser.id, false)
    if not target then return _tip("Need 2 squads on level") end
    _probe_start(chaser, target, 10, 3)
end

--- @export console
function chase_probe_far()
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local level_id = xlevel.get_level_id(alife():actor())
    local apos = actor:position()
    local chaser = _pick_squad(apos, level_id, nil, true)
    if not chaser then return _tip("No squad on level") end
    local target = _pick_squad(apos, level_id, chaser.id, false)
    if not target then return _tip("Need 2 squads on level") end
    _probe_start(chaser, target, 18, 5)
end

local function _find_nearest_alpha()
    local actor = db.actor
    if not actor then return nil, "Not in game" end
    local sim = alife()
    local actor_se = sim:actor()
    if not actor_se then return nil, "No actor entity" end
    local actor_level = xlevel.get_level_id(actor_se)
    local pos = actor:position()
    local alphas = ap_ext_tracker.get_alphas()
    local total, on_level = 0, 0
    local best_id, best_data, best_dist, best_pos = nil, nil, math_huge, nil
    for npc_id, data in pairs(alphas) do
        total = total + 1
        if data.level_id ~= actor_level then goto skip end
        on_level = on_level + 1
        local se = sim:object(npc_id)
        if not se then goto skip end
        local dist = pos:distance_to(se.position)
        if dist < best_dist then
            best_id = npc_id
            best_data = data
            best_dist = dist
            best_pos = se.position
        end
        ::skip::
    end
    ap_core_debug.debug("[TEST] alpha_search total=%d on_level=%d level_id=%d", total, on_level, actor_level)
    if not best_id then return nil, "No alphas on this level" end
    local squad = xsquad.get_squad_by_member(best_id)
    if not squad then
        ap_core_debug.debug("[TEST] alpha_search no_squad npc_id=%d", best_id)
        return nil, "Alpha squad not found"
    end
    return { id = best_id, data = best_data, dist = best_dist, pos = best_pos, squad = squad }
end

--- @export console
function pull_alpha()
    ap_core_debug.debug("[TEST] pull_alpha pressed")
    local result, reason = _find_nearest_alpha()
    if not result then
        ap_core_debug.debug("[TEST] pull_alpha SKIP %s", reason)
        return _tip(reason)
    end
    local actor = db.actor
    local pos = actor:position()
    local tp = vector():set(pos.x + 10, pos.y, pos.z)
    TeleportSquad(result.squad, tp, actor:level_vertex_id(), actor:game_vertex_id())
    local name = xcreature.get_name(result.id) or "?"
    ap_core_debug.debug("[TEST] pull_alpha OK npc_id=%d squad_id=%d level=%d name=%s dist=%d community=%s",
        result.id, result.squad.id, result.data.level, name,
        math_floor(result.dist), result.squad:get_squad_community())
    _tip("Pulled alpha L" .. result.data.level .. " " .. name .. " from " .. math_floor(result.dist) .. "m")
end

--- @export console
function goto_alpha()
    ap_core_debug.debug("[TEST] goto_alpha pressed")
    local result, reason = _find_nearest_alpha()
    if not result then
        ap_core_debug.debug("[TEST] goto_alpha SKIP %s", reason)
        return _tip(reason)
    end
    db.actor:set_actor_position(result.pos)
    local name = xcreature.get_name(result.id) or "?"
    ap_core_debug.debug("[TEST] goto_alpha OK npc_id=%d squad_id=%d level=%d name=%s dist=%d community=%s",
        result.id, result.squad.id, result.data.level, name,
        math_floor(result.dist), result.squad:get_squad_community())
    _tip("Teleported to alpha L" .. result.data.level .. " " .. name .. " (" .. math_floor(result.dist) .. "m)")
end

local CONSEQUENCE = ap_core_const.CONSEQUENCE
local NEEDS_ARRIVE_KEYS = {
    [CONSEQUENCE.HUNGER_CAMPFIRE] = true, [CONSEQUENCE.SLEEP_CAMPFIRE] = true, [CONSEQUENCE.REST_CAMPFIRE] = true,
    [CONSEQUENCE.HEAL_SHELTER] = true, [CONSEQUENCE.SHELTER_INDOOR] = true, [CONSEQUENCE.SHELTER_OUTDOOR] = true,
    [CONSEQUENCE.MONEY_HARVEST] = true, [CONSEQUENCE.MONEY_HUNT] = true, [CONSEQUENCE.SUPPLY_TRADER] = true,
    [CONSEQUENCE.JOB_OUTPOST] = true, [CONSEQUENCE.JOB_EXPLORE] = true, [CONSEQUENCE.JOB_RESEARCH] = true,
    [CONSEQUENCE.SOCIAL_CAMPFIRE] = true, [CONSEQUENCE.SOCIAL_BASE] = true,
}

--- @export console
function goto_need()
    ap_core_debug.debug("[TEST] goto_need pressed")
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local sim = alife()
    local actor_community = db.actor:character_community()
    local scripted = ap_core_broker.get_scripted_squads()
    for squad_id, data in pairs(scripted) do
        local rec = ap_core_record.get_record({ squad_id = squad_id, assigned = true })
        local cons = rec and rec.consequence
        if not NEEDS_ARRIVE_KEYS[cons] then goto skip end
        local squad = sim:object(squad_id)
        if not squad then goto skip end
        if game_relations.is_factions_enemies(actor_community, squad:get_squad_community()) then goto skip end
        local cmd_se = xobject.se(squad:commander_id())
        if not cmd_se then goto skip end
        db.actor:set_actor_position(cmd_se.position)
        local name = cmd_se:character_name()
        ap_core_debug.debug("[TEST] goto_need OK squad=%d need=%s target=%s npc=%s",
            squad_id, cons, data.scripted_target, name)
        _tip("Teleported to " .. name .. " (" .. cons .. " -> " .. data.scripted_target .. ")")
        do return end
        ::skip::
    end
    _tip("No friendly squad filling a need right now")
    ap_core_debug.debug("[TEST] goto_need SKIP no_friendly_need_squad")
end

--- @export console
function spawn_artefact()
    ap_core_debug.debug("[TEST] spawn_artefact pressed")
    local actor = db.actor
    if not actor then
        ap_core_debug.debug("[TEST] spawn_artefact SKIP no_actor")
        return _tip("Not in game")
    end
    local sec = xmath.sample(ARTEFACTS)
    local se = xinventory.create_item(sec, actor:id())
    if se then
        ap_core_debug.debug("[TEST] spawn_artefact OK sec=%s", sec)
        _tip("Spawned " .. sec)
    else
        ap_core_debug.debug("[TEST] spawn_artefact FAIL sec=%s", sec)
        _tip("Failed to spawn " .. sec)
    end
end

local KIT_EQUIPMENT_ITEMS = {
    -- weapon + ammo + knife
    { sec = "wpn_mossberg590",       count = 1 },
    { sec = "ammo_12x70_buck",       count = 180 },
    { sec = "wpn_knife5",            count = 1 },
    -- armor + backpack
    { sec = "scientific_outfit",     count = 1 },
    { sec = "equ_tourist_pack",      count = 1 },
}

local KIT_CONSUMABLES_ITEMS = {
    -- meds (top-tier first)
    { sec = "medkit_scientic",       count = 10 },
    { sec = "medkit_army",           count = 20 },
    { sec = "bandage",               count = 30 },
    { sec = "drug_anabiotic",        count = 5 },
    { sec = "drug_sleepingpills",    count = 30 },
    { sec = "antirad",               count = 20 },
    { sec = "drug_radioprotector",   count = 10 },
    -- food + water
    { sec = "kolbasa",               count = 10 },
    { sec = "conserva",              count = 10 },
    { sec = "bread",                 count = 10 },
    { sec = "water_drink",           count = 20 },
    { sec = "vodka_quality",         count = 5 },
}

local function _spawn_kit_items(items, label)
    local id = db.actor:id()
    local spawned, skipped = 0, 0
    for i = 1, #items do
        local item = items[i]
        if not ini_sys:section_exist(item.sec) then
            ap_core_debug.debug("[TEST] %s SKIP missing section=%s", label, item.sec)
            skipped = skipped + 1
            goto continue
        end
        for idx = 1, item.count do
            xinventory.create_item(item.sec, id)
        end
        spawned = spawned + 1
        ::continue::
    end
    return spawned, skipped
end

--- Spawn playtest equipment (weapon, armor, backpack, money, fast travel, scorcher off)
--- @export console
function kit_equipment()
    ap_core_debug.debug("[TEST] kit_equipment pressed")
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local spawned, skipped = _spawn_kit_items(KIT_EQUIPMENT_ITEMS, "kit_equipment")
    xcreature.give_money(actor, 500000)
    ui_options.set("gameplay/fast_travel/state", 2)
    game_fast_travel.update_settings()
    xactor.give_info("drx_sl_brain_scorcher_switch_off")
    _tip(string_format("Kit equipment: %d items, %d skipped + 500k + travel + scorcher off", spawned, skipped))
    ap_core_debug.debug("[TEST] kit_equipment OK spawned=%d skipped=%d", spawned, skipped)
end

--- Spawn playtest consumables (meds, food, water)
