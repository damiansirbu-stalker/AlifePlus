--- _ap_deps: AlifePlus dependency gate and version metadata

local assert, tostring, type, math_floor = assert, tostring, type, math.floor

local MOD_NAME = "AlifePlus"
local _VERSION = "1.8.2"
local XLIBS_MIN_VERSION = "1.8.1"
local XLIBS_URL = "https://www.moddb.com/mods/stalker-anomaly/addons/xlibs-1001"

-- Modded-exes minimum build in YYYYMMDD format. 20250908 = AOEngine v0.55 baseline
-- (binary build date 2025-09-08; equivalent demonized release is tag 2025.9.10).
-- get_modded_exes_version() returns __DATE__ parsed as years*10000 + months*100 + days
-- (engine src: script_ini_file_script.cpp:95-125).
local DEMONIZED_MIN_VERSION = 20250908
local DEMONIZED_URL = "https://github.com/themrdemonized/xray-monolith"
local AOENGINE_URL  = "https://github.com/Mirrowel/AOEngine-Assets"

--- @return string Version string
function get_version()
    return _VERSION
end

-- The demonized build this release is built and tested against - set to the LATEST demonized at
-- every release (compatibility-standards.md "The target build"). The platform footer shows fully
-- compatible only at or above it; older demonized builds and AOEngine (judged as its 2025.9.8
-- fork base) show partially compatible.
local TARGET_DEMONIZED = 20260706

-- xray-monolith build (YYYYMMDD) as the themrdemonized tag style, no zero padding (20260706 -> "2026.7.6").
local function _build_tag(build)
    return math_floor(build / 10000) .. "." .. (math_floor(build / 100) % 100) .. "." .. (build % 100)
end

-- AOEngine v0.55 is cut from the 2025-09-08 xray-monolith fork state (compatibility-standards.md), so
-- AOE is judged as an engine frozen at this build: any newer target reads partially compatible on AOE.
local AOE_BASELINE_BUILD = 20250908

-- Platform status line + verdict for the boot log and the MCM footer. Self-contained here (not in xlibs)
-- so it renders even when xlibs is missing or too old - the case the deps asserts exist to report. The
-- xlibs version is read defensively for the same reason: the reporter must survive a bad xlibs.
function platform_status()
    local xver = (xlibs and xlibs.get_version and xlibs.get_version()) or "?"
    local line = MOD_NAME .. " " .. _VERSION .. ", xlibs " .. xver
    local has_build = type(get_modded_exes_version) == "function"
    local effective
    if type(get_aoe_version) == "function" then
        line = line .. ", AOEngine " .. tostring(get_aoe_version())
        if has_build then line = line .. ", xray-monolith " .. _build_tag(get_modded_exes_version()) end
        effective = AOE_BASELINE_BUILD
    elseif has_build then
        local build = get_modded_exes_version()
        line = line .. ", xray-monolith " .. _build_tag(build)
        effective = build
    else
        return line .. " (incompatible)", "blocked"
    end
    if effective < TARGET_DEMONIZED then
        return line .. " (partially compatible)", "fallback"
    end
    return line .. " (fully compatible)", "full"
end

-- MCM ui_hook_functor for the footer row: writes platform_status into the desc widget, colored by
-- verdict. Colors build lazily (GetARGB is absent under the static validator).
local _footer_clr = nil
function platform_functor()
    return function(_anchor, handlers)
        if not _footer_clr then
            _footer_clr = {
                full     = GetARGB(255, 170, 220, 170),
                fallback = GetARGB(255, 230, 210, 120),
                blocked  = GetARGB(255, 220, 120, 120),
            }
        end
        local line, level = platform_status()
        handlers.desc:SetText(line)
        handlers.desc:SetTextColor(_footer_clr[level])
    end
end

function on_game_start()
    assert(xlog,
        "\n\n! [" .. MOD_NAME .. "] xlibs is not installed.\n"..
        "! " .. MOD_NAME .. " requires xlibs to function.\n"..
        "! Install xlibs and restart the game.\n"..
        "! " .. XLIBS_URL .. "\n"
    )

    assert(xlibs and xlibs.is_compatible,
        "\n\n! [" .. MOD_NAME .. "] xlibs is outdated (no compatibility API).\n"..
        "! Update xlibs and restart the game.\n"..
        "! " .. XLIBS_URL .. "\n"
    )

    assert(xlibs.is_compatible(XLIBS_MIN_VERSION),
        "\n\n! [" .. MOD_NAME .. "] xlibs " .. (xlibs.get_version()) .. " is not compatible.\n"..
        "! " .. MOD_NAME .. " requires xlibs >= " .. XLIBS_MIN_VERSION .. ".\n"..
        "! Update both xlibs and " .. MOD_NAME .. ", then restart the game.\n"..
        "! " .. XLIBS_URL .. "\n"
    )

    local has_aoe       = type(get_aoe_version)         == "function"
    local has_demonized = type(get_modded_exes_version) == "function"

    assert(has_aoe or has_demonized,
        "\n\n! [" .. MOD_NAME .. "] modded exes not detected.\n"..
        "! " .. MOD_NAME .. " requires themrdemonized modded exes or AOEngine.\n"..
        "! demonized: " .. DEMONIZED_URL .. "\n"..
        "! AOEngine:  " .. AOENGINE_URL .. "\n"
    )

    local demonized_build = has_demonized and get_modded_exes_version() or nil
    if has_demonized and not has_aoe then
        assert(demonized_build >= DEMONIZED_MIN_VERSION,
            "\n\n! [" .. MOD_NAME .. "] demonized build " .. tostring(demonized_build) ..
            " is older than required.\n"..
            "! " .. MOD_NAME .. " requires demonized build " ..
            tostring(DEMONIZED_MIN_VERSION) .. " or later.\n"..
            "! Update: " .. DEMONIZED_URL .. "\n"
        )
    end

    -- The boot platform line and the MCM footer come from the same builder, so they never drift.
    xlog.get_logger(MOD_NAME, { outfile = MOD_NAME:lower() .. ".log" })
        .info("%s", (platform_status()))
end
