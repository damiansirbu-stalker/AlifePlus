--- ap_ext_consequence_harvest_hunt: Outlaws and mutants chase artefact takers

local ipairs = ipairs

local RESULT = ap_core_const.RESULT
local REASON = ap_ext_const.REASON
local CAUSE = ap_ext_const.CAUSE
local CONSEQUENCE = ap_ext_const.CONSEQUENCE
local ACTION = ap_ext_const.ACTION
local TRACE = ap_core_const.TRACE

local cfg = ap_core_mcm.cfg
local community_harvest = ap_ext_const.community_harvest

local function _move_actor_chasers(squads, moved)
    for _, chaser in ipairs(squads) do
        local res = ap_core_squad.script_actor_target(chaser)
        if res and res.code == RESULT.OK_NEXT then moved[#moved + 1] = chaser end
    end
end

local function _move_smart_chasers(squads, smart, target_squad_id, moved)
    for _, chaser in ipairs(squads) do
        local res = ap_core_squad.script_squad(chaser, smart, {
            rush = cfg.consequence_harvest_hunt_rush,
            on_arrive = CONSEQUENCE.HARVEST_HUNT,
            on_arrive_args = { target_squad_id = target_squad_id },
        })
        if res and res.code == RESULT.OK_NEXT then moved[#moved + 1] = chaser end
    end
end

local function _on_arrive(squad, args)
    local target_squad_id = args.target_squad_id
    if not target_squad_id then return end
    local chase_count = (args.chase_count or 0) + 1
    if chase_count > cfg.consequence_harvest_hunt_max_chases then
        ap_core_debug.debug("[CONSEQUENCE.HARVEST_HUNT] chase_limit: squad=%d chases=%d", squad.id, chase_count)
        return
    end
    local target_squad = xobject.se(target_squad_id)
    if not target_squad then
        ap_core_utils.send_pda(cfg.consequence_harvest_hunt_pda_chance, "text_pda_consequence_harvest_hunt_lost")
        return
    end
    local level_id = xlevel.get_level_id(target_squad)
    if not level_id then return end
    if xlevel.get_level_id(squad) ~= level_id then
        ap_core_utils.send_pda(cfg.consequence_harvest_hunt_pda_chance, "text_pda_consequence_harvest_hunt_lost")
        return
    end
    ap_core_debug.observe(nil, ACTION.CHASE_TARGET, function()
        local smart = ap_core_utils.find_smart(target_squad.position, {
            level_id = level_id, max_distance = ap_ext_const.RADIUS_DISTANT_MAX,
        })
        if not smart then return { code = TRACE.NO_SMART } end
        if xsmart.is_arrived(squad, smart) then
            ap_core_utils.send_pda(cfg.consequence_harvest_hunt_pda_chance, "text_pda_consequence_harvest_hunt_found")
            return { code = TRACE.CO_LOCATED, id = squad.id, chase = chase_count }
        end
        local res = ap_core_squad.script_squad(squad, smart, {
            rush = cfg.consequence_harvest_hunt_rush,
            on_arrive = CONSEQUENCE.HARVEST_HUNT,
            on_arrive_args = { target_squad_id = target_squad_id, chase_count = chase_count },
        })
        if res.code ~= RESULT.OK_NEXT then return { code = res.code, reason = res.reason } end
        return { code = TRACE.OK, id = squad.id, dst_id = smart.id, chase = chase_count }
    end)
end

local function _handler(event_data)
    local trace = event_data._trace
    return ap_core_debug.observe(trace, CONSEQUENCE.HARVEST_HUNT, function()
        if not cfg.consequence_harvest_hunt_enabled then return { code = RESULT.DISABLED_NEXT } end
        if not xmath.chance(cfg.consequence_harvest_hunt_chance) then return { code = RESULT.CHANCE_NEXT, chance = cfg.consequence_harvest_hunt_chance } end

        local taker_is_player = event_data.taker_is_player
        local taker_squad_id = event_data.taker_squad_id
        local position, level_id = event_data.position, event_data.level_id
        if not position then return { code = RESULT.RULES_NEXT, reason = REASON.NO_POS } end

        local chasers = ap_core_utils.find_squads_observed(trace, position, {
            factions = community_harvest,
            min_distance = ap_ext_const.RADIUS_CLOSE_MAX, max_distance = ap_ext_const.RADIUS_DISTANT_MAX,
            level_id = level_id, max_count = cfg.consequence_harvest_hunt_max_squads,
            exclude_squad_id = event_data.taker_squad_id,
        })
        if #chasers == 0 then return { code = RESULT.RULES_NEXT, reason = REASON.NO_SQUAD } end

        local target_squad
        if not taker_is_player then
            target_squad = xobject.se(taker_squad_id)
            if not target_squad then return { code = RESULT.RULES_NEXT, reason = REASON.NO_TARGET_SQUAD } end
        end

        local moved = {}
        local dst_id = 0
        local location = ap_core_utils.get_location_description(nil, position, level_id)
        ap_core_debug.observe(trace, ACTION.MOVE_SQUAD, function()
            if not chasers then return { code = TRACE.NO_SQUADS } end
            if taker_is_player then
                _move_actor_chasers(chasers, moved)
            else
                local smart = ap_core_utils.find_smart(target_squad.position, {
                    level_id = level_id, max_distance = ap_ext_const.RADIUS_DISTANT_MAX,
                })
                if not smart then return { code = TRACE.NO_SMART } end
                dst_id = smart.id
                _move_smart_chasers(chasers, smart, taker_squad_id, moved)
            end
            return ap_core_debug.result_squads(moved, { dst_id = dst_id, rejected = #chasers - #moved })
        end)
        if #moved == 0 then return { code = RESULT.RULES_NEXT, reason = REASON.MOVE_FAILED } end

        ap_core_debug.observe(trace, ACTION.SEND_PDA, function()
            return ap_core_utils.send_pda(cfg.consequence_harvest_hunt_pda_chance,
                "text_pda_consequence_harvest_hunt", { location = location })
        end)
        for i = 1, #moved do ap_core_squad.add_marked_squad(moved[i].id, CONSEQUENCE.HARVEST_HUNT) end

        return ap_core_debug.result_squads(moved, {
            code = RESULT.OK_STOP, reason = #moved .. "_hunters", dst_id = dst_id,
        })
    end)
end

function on_game_start()
    ap_core_consumer.register(CONSEQUENCE.HARVEST_HUNT, {
        event = CAUSE.HARVEST,
        priority = 15,
        condition = function() return cfg.consequence_harvest_hunt_enabled end,
        on_arrive = _on_arrive,
    }, _handler)
    ap_core_debug.info("[CONSEQUENCE.HARVEST_HUNT] Initialized")
end
